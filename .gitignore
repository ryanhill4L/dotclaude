# Ignore everything by default
*

# Track configuration
!.gitignore
!CLAUDE.md
!settings.json

# Track custom agents
!agents/
!agents/**

# Track custom skills
!skills/
!skills/**

# Track custom commands
!commands/
!commands/**

# Track plugin configs (not caches)
!plugins/
!plugins/config.json
!plugins/claude-hud/
!plugins/claude-hud/config.json

# Ignore all .DS_Store files
.DS_Store
